{
    "require": {
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "firebase/php-jwt": "^6.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "audit": {
            "block-insecure": false
        }
    },
    "audit": {
        "ignore": ["PKSA-y2cr-5h3j-g3ys"]
    }
}